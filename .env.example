# Copy to .env and fill in. Never commit the real .env file.

# Devin v3 service-user credentials (Settings -> API Keys in your Devin org)
DEVIN_API_KEY=
DEVIN_ORG_ID=

# GitHub PAT with issues + pull-requests read/write on the target repo
GITHUB_TOKEN=
GITHUB_REPO=deonmenezes/superset
GITHUB_ISSUE_LABEL=devin-remediate

# Shared secret configured on the GitHub webhook (Settings -> Webhooks)
GITHUB_WEBHOOK_SECRET=changeme

# Safety: true = parse/group/plan but never call Devin or open PRs/comments.
# Flip to false only once you've reviewed a dry-run /plan and /trigger output.
DRY_RUN=true

# How many new packages to dispatch per trigger (webhook, rescan, or manual)
DISPATCH_LIMIT_PER_RUN=3
# Per-session ACU cap passed to Devin
MAX_ACU_PER_SESSION=15
# How often the background job polls running sessions for status updates
POLL_INTERVAL_SECONDS=45

# --- Autonomy ---------------------------------------------------------------
# How often the engine re-scans the backlog and self-dispatches new work, with
# no webhook and no button click. Non-zero = fully hands-free loop; 0 reverts to
# webhook/manual-only. A newly-filed issue is picked up within one interval.
RESCAN_INTERVAL_SECONDS=120
# Run one dispatch pass ~8s after boot so the engine acts immediately on startup
# instead of waiting a full rescan interval. Ignored in dry-run.
DISPATCH_ON_STARTUP=true

# Run ledger (SQLite). In Docker this is the mounted /data volume; locally the
# engine falls back to ./data/runs.db automatically if /data isn't writable.
DB_PATH=/data/runs.db
PORT=8000

# Voice briefing - "call me and read this report aloud" button on /report.
# All three Twilio vars are required to enable calling; leave blank to disable.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A voice-capable Twilio number in E.164, e.g. +16282981759
TWILIO_FROM_NUMBER=
# Optional: with an Anthropic key the spoken script is written by Claude;
# without it, a deterministic template is used instead (calling still works).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
